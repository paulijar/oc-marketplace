---
import Logo from "../components/Logo.astro";
import ExternalLink from "../components/ExternalLink.astro";
import SocialLinks from "../components/SocialLinks.astro";
import MembershipBadges from "../components/MembershipBadges.astro";
import { withBase } from "../lib/catalog.ts";

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const home = withBase(base, "");

// Which platform's catalog the current page belongs to, so the header switch
// can highlight it. Extension routes live under /extensions; everything else
// (home catalog, app detail pages) is ownCloud Classic.
const path = Astro.url.pathname;
const onExtensions = path.includes("/extensions");
const platform: "classic" | "ocis" = onExtensions ? "ocis" : "classic";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {/* Favicons vendored from owncloud.com's official brand asset set. */}
    <link rel="icon" type="image/x-icon" href={withBase(base, "favicon.ico")} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase(base, "favicon-32x32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase(base, "favicon-16x16.png")} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase(base, "apple-touch-icon.png")} />
    <link rel="manifest" href={withBase(base, "site.webmanifest")} />
    <meta name="theme-color" content="#041e42" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        /* ownCloud brand palette — sourced from owncloud/web themes/owncloud/theme.json */
        --oc-brand: #041e42;
        --oc-brand-hover: #223959;
        --oc-primary: #4a76ac;
        --oc-primary-hover: #2c588e;
        --oc-contrast: #ffffff;
        --oc-text: #041e42;
        --oc-text-muted: #4c5f79;
        --oc-bg: #ffffff;
        --oc-bg-muted: #f8f8f8;
        --oc-bg-highlight: #edf3fa;
        --oc-border: #ecebee;
        --oc-border-input: #ceddee;
        --oc-success: #03543f;

        --radius: 12px;
        --radius-sm: 8px;
        --shadow-sm: 0 1px 2px rgba(4, 30, 66, 0.06);
        --shadow-md: 0 6px 20px -8px rgba(4, 30, 66, 0.18);
        --shadow-lg: 0 24px 60px -24px rgba(4, 30, 66, 0.35);
        --container: 1120px;
        --font-sans: "Source Sans 3", ui-sans-serif, system-ui, sans-serif;
        --font-mono: "IBM Plex Mono", ui-monospace, "SF Mono", monospace;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--oc-text);
        background: var(--oc-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: var(--oc-primary-hover);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin: 0;
      }

      .container {
        width: 100%;
        max-width: var(--container);
        margin-inline: auto;
        padding-inline: 24px;
      }

      /* ---- Site header ---- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: saturate(150%) blur(10px);
        border-bottom: 1px solid var(--oc-border);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 68px;
        gap: 24px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--oc-brand);
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand__logo {
        height: 34px;
        width: auto;
        display: block;
      }
      .brand__tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--oc-text-muted);
        padding-left: 13px;
        margin-left: 1px;
        border-left: 1px solid var(--oc-border);
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .nav a {
        color: var(--oc-text);
      }
      .nav a:hover {
        color: var(--oc-primary-hover);
        text-decoration: none;
      }
      /* Segmented switch between the two platform catalogs (Classic / oCIS). */
      .platform-switch {
        display: inline-flex;
        padding: 3px;
        border: 1px solid var(--oc-border-input);
        border-radius: 999px;
        background: var(--oc-bg-muted);
      }
      .platform-switch__opt {
        padding: 5px 14px;
        border-radius: 999px;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--oc-text-muted);
        line-height: 1.2;
      }
      .platform-switch__opt:hover {
        color: var(--oc-primary-hover);
        text-decoration: none;
      }
      .platform-switch__opt[data-active="true"] {
        background: var(--oc-brand);
        color: var(--oc-contrast);
      }
      .platform-switch__opt[data-active="true"]:hover {
        color: var(--oc-contrast);
      }

      .nav__cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--oc-brand);
        color: var(--oc-contrast) !important;
        padding: 9px 18px;
        border-radius: 999px;
        transition:
          background 0.18s ease,
          transform 0.18s ease;
      }
      .nav__cta:hover {
        background: var(--oc-brand-hover);
        text-decoration: none;
        transform: translateY(-1px);
      }
      @media (max-width: 720px) {
        .nav__links {
          display: none;
        }
        .brand__tag {
          display: none;
        }
      }

      /* ---- Footer ---- */
      .site-footer {
        margin-top: 96px;
        background: var(--oc-brand);
        color: rgba(255, 255, 255, 0.72);
      }
      .site-footer__inner {
        display: flex;
        flex-wrap: wrap;
        gap: 32px 64px;
        justify-content: space-between;
        padding-block: 56px 40px;
      }
      .site-footer__brand {
        max-width: 320px;
      }
      .site-footer__logo {
        height: 26px;
        color: #fff;
        margin-bottom: 16px;
      }
      .site-footer p {
        margin: 0 0 12px;
        font-size: 0.92rem;
      }
      .site-footer__cols {
        display: flex;
        gap: 56px;
        flex-wrap: wrap;
      }
      .site-footer h4 {
        color: #fff;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0 0 14px;
      }
      .site-footer ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 9px;
        font-size: 0.92rem;
      }
      .site-footer a {
        color: rgba(255, 255, 255, 0.72);
      }
      .site-footer a:hover {
        color: #fff;
      }
      .site-footer__legal {
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        padding-block: 20px 28px;
        font-size: 0.84rem;
        display: flex;
        flex-wrap: wrap;
        gap: 8px 20px;
        justify-content: space-between;
      }
      .site-footer__legal-links {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      /* ---- Leave-the-site notice ---- */
      .leave-notice {
        border: none;
        border-radius: var(--radius);
        padding: 28px;
        max-width: 440px;
        width: calc(100% - 32px);
        box-shadow: var(--shadow-lg);
        color: var(--oc-text);
      }
      .leave-notice::backdrop {
        background: rgba(4, 30, 66, 0.45);
        backdrop-filter: blur(2px);
      }
      .leave-notice__title {
        font-size: 1.25rem;
        color: var(--oc-brand);
        margin-bottom: 12px;
      }
      .leave-notice__text {
        margin: 0 0 6px;
        color: var(--oc-text-muted);
        font-size: 0.95rem;
      }
      .leave-notice__host {
        margin: 0 0 4px;
        font-size: 1.05rem;
        word-break: break-word;
      }
      .leave-notice__url {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--oc-text-muted);
        word-break: break-all;
      }
      .leave-notice__actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 24px;
      }
      .leave-notice__btn {
        font: inherit;
        font-weight: 600;
        cursor: pointer;
        padding: 10px 20px;
        border-radius: 999px;
        border: 1px solid var(--oc-border-input);
        background: var(--oc-bg);
        color: var(--oc-text);
        transition:
          background 0.18s ease,
          transform 0.18s ease;
      }
      .leave-notice__btn:hover {
        background: var(--oc-bg-muted);
      }
      .leave-notice__btn--go {
        border-color: var(--oc-brand);
        background: var(--oc-brand);
        color: var(--oc-contrast);
      }
      .leave-notice__btn--go:hover {
        background: var(--oc-brand-hover);
        transform: translateY(-1px);
      }

      :focus-visible {
        outline: 2px solid var(--oc-primary);
        outline-offset: 2px;
        border-radius: 4px;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href={home} aria-label="ownCloud Marketplace home">
          <Logo class="brand__logo" />
          <span class="brand__tag">Marketplace</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <span class="nav__links" style="display:contents">
            <span
              class="platform-switch"
              role="group"
              aria-label="Choose ownCloud platform"
            >
              <a
                class="platform-switch__opt"
                href={withBase(base, "#catalog")}
                aria-current={platform === "classic" ? "true" : undefined}
                data-active={platform === "classic"}
              >
                Classic
              </a>
              <a
                class="platform-switch__opt"
                href={withBase(base, "extensions")}
                aria-current={platform === "ocis" ? "true" : undefined}
                data-active={platform === "ocis"}
              >
                Infinite Scale
              </a>
            </span>
            <a href={withBase(base, "downloads")}>Downloads</a>
            <ExternalLink href="https://doc.owncloud.com">Docs</ExternalLink>
            <ExternalLink href="https://github.com/owncloud/marketplace">GitHub</ExternalLink>
          </span>
          <ExternalLink
            class="nav__cta"
            href="https://github.com/owncloud/marketplace/blob/main/.github/pull_request_template.md"
          >
            Publish an app
          </ExternalLink>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div class="site-footer__brand">
          <Logo class="site-footer__logo" />
          <p>
            A backend-free, community-driven app marketplace for ownCloud. The
            Git repository is the source of truth: no server, no database.
          </p>
        </div>
        <div class="site-footer__cols">
          <div>
            <h4>Marketplace</h4>
            <ul>
              <li><a href={withBase(base, "#catalog")}>Browse apps</a></li>
              <li><a href={withBase(base, "extensions")}>Web Extensions</a></li>
              <li><a href={withBase(base, "downloads")}>Downloads</a></li>
              <li>
                <ExternalLink
                  href="https://github.com/owncloud/marketplace/blob/main/.github/pull_request_template.md"
                  >Publish</ExternalLink
                >
              </li>
              <li><a href={withBase(base, "api/v1/apps.json")}>JSON API</a></li>
            </ul>
          </div>
          <div>
            <h4>ownCloud</h4>
            <ul>
              <li><ExternalLink href="https://owncloud.com">Website</ExternalLink></li>
              <li><ExternalLink href="https://doc.owncloud.com">Documentation</ExternalLink></li>
              <li>
                <ExternalLink href="https://github.com/orgs/owncloud/discussions"
                  >Discussions</ExternalLink
                >
              </li>
            </ul>
          </div>
          <div>
            <h4>Connect</h4>
            <SocialLinks />
            <MembershipBadges />
          </div>
        </div>
      </div>
      <div class="container site-footer__legal">
        <span>Apache-2.0 licensed · Stewarded by the Kiteworks OSPO.</span>
        <span class="site-footer__legal-links">
          <ExternalLink href="https://owncloud.com/imprint/">Imprint</ExternalLink>
          <span aria-hidden="true">·</span>
          <span>© ownCloud – a Kiteworks company.</span>
        </span>
      </div>
    </footer>

    {/* Leave notice: confirms before any outbound navigation link sends the
        user off-site. Populated and opened by the script below; the page
        still works (links open in a new tab) if that script never runs. */}
    <dialog class="leave-notice" aria-labelledby="leave-notice-title">
      <h2 id="leave-notice-title" class="leave-notice__title">
        You're leaving the Marketplace
      </h2>
      <p class="leave-notice__text">
        This link opens an external site in a new tab:
      </p>
      <p class="leave-notice__host"><strong data-leave-host></strong></p>
      <p class="leave-notice__url" data-leave-url></p>
      <div class="leave-notice__actions">
        <button type="button" class="leave-notice__btn" data-leave-cancel>
          Cancel
        </button>
        <button
          type="button"
          class="leave-notice__btn leave-notice__btn--go"
          data-leave-continue
        >
          Continue ↗
        </button>
      </div>
    </dialog>

    <script>
      // Intercept clicks on outbound navigation links (marked by
      // ExternalLink.astro) and confirm before sending the user off-site.
      const dialog = document.querySelector<HTMLDialogElement>(".leave-notice");
      const hostEl = dialog?.querySelector<HTMLElement>("[data-leave-host]");
      const urlEl = dialog?.querySelector<HTMLElement>("[data-leave-url]");
      const cancelBtn = dialog?.querySelector<HTMLButtonElement>("[data-leave-cancel]");
      const continueBtn = dialog?.querySelector<HTMLButtonElement>("[data-leave-continue]");

      let pendingUrl: string | null = null;

      if (dialog && hostEl && urlEl && cancelBtn && continueBtn) {
        document.addEventListener("click", (event) => {
          // Honor modifier-clicks (new tab/window) and non-primary buttons.
          if (
            event.defaultPrevented ||
            (event as MouseEvent).button !== 0 ||
            (event as MouseEvent).metaKey ||
            (event as MouseEvent).ctrlKey ||
            (event as MouseEvent).shiftKey ||
            (event as MouseEvent).altKey
          )
            return;

          const link = (event.target as Element | null)?.closest<HTMLAnchorElement>(
            "a[data-external-link]",
          );
          if (!link) return;

          event.preventDefault();
          pendingUrl = link.href;
          let host = link.href;
          try {
            host = new URL(link.href).hostname;
          } catch {
            // Leave host as the raw href if it does not parse as a URL.
          }
          hostEl.textContent = host;
          urlEl.textContent = link.href;
          dialog.showModal();
        });

        const close = () => {
          pendingUrl = null;
          dialog.close();
        };

        continueBtn.addEventListener("click", () => {
          if (pendingUrl) window.open(pendingUrl, "_blank", "noopener,noreferrer");
          close();
        });
        cancelBtn.addEventListener("click", close);

        // Click on the backdrop (outside the dialog box) dismisses it.
        dialog.addEventListener("click", (event) => {
          if (event.target === dialog) close();
        });
        // Esc-to-close fires the native cancel event; clear pending state.
        dialog.addEventListener("cancel", () => {
          pendingUrl = null;
        });
      }
    </script>
  </body>
</html>
