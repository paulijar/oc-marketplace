---
import Base from "../layouts/Base.astro";
import ExternalLink from "../components/ExternalLink.astro";
import StoreBadge from "../components/StoreBadge.astro";
import { loadDownloads, withBase, type DownloadSurface } from "../lib/catalog.ts";
import { SURFACES } from "../lib/downloads.ts";

const downloads = await loadDownloads();
const base = import.meta.env.BASE_URL;

const surfaces = SURFACES.map((s) => ({
  ...s,
  surface: (downloads?.[s.key] ?? null) as DownloadSurface | null,
}));

// "2026-02-01T…" → "1 Feb 2026"; defensive against a missing/odd value.
const fmtDate = (iso: string): string => {
  const d = new Date(iso);
  return Number.isNaN(d.getTime())
    ? iso
    : d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
};

const fmtCount = (n: number) => n.toLocaleString("en-US");
const fmtDownloads = (n: number) => `${fmtCount(n)} download${n === 1 ? "" : "s"}`;

// "★ 4.5 · 345 ratings" from a store's rating/ratingCount, when present.
const fmtRating = (rating?: number, count?: number): string | null => {
  if (rating === undefined) return null;
  const stars = `★ ${rating.toFixed(1)}`;
  return count === undefined
    ? stars
    : `${stars} · ${fmtCount(count)} rating${count === 1 ? "" : "s"}`;
};

const generated = downloads ? fmtDate(downloads.generatedAt) : null;
---
<Base
  title="Downloads: ownCloud"
  description="Download the latest ownCloud Infinite Scale, ownCloud Classic, the desktop client and the Android and iOS apps. Direct binaries for Linux, macOS and Windows, plus the official mobile app stores."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="eyebrow">Open Source Program Office · Releases</p>
      <h1 class="hero__title">Download <span class="hero__accent">ownCloud</span>.</h1>
      <p class="hero__lede">
        The latest stable releases of Infinite Scale, ownCloud Classic, the
        desktop client and the Android &amp; iOS apps, pulled straight from the
        official sources.
      </p>
      {generated && <p class="hero__note">Release data refreshed {generated}.</p>}
    </div>
  </section>

  <!-- ===================== SURFACES ===================== -->
  <section class="surfaces container">
    {
      surfaces.map(({ key, name, tagline, repo, dockerImage, surface }) => (
        <article class="surface" id={key}>
          <header class="surface__head">
            <div>
              <h2 class="surface__name">{name}</h2>
              <p class="surface__tagline">{tagline}</p>
            </div>
            {surface && (
              <div class="surface__release">
                <ExternalLink class="surface__version" href={surface.releaseUrl}>
                  v{surface.version}
                </ExternalLink>
                <span class="surface__date">{fmtDate(surface.publishedAt)}</span>
                {surface.store?.installs && (
                  <span class="surface__downloads">{surface.store.installs} installs</span>
                )}
                {fmtRating(surface.store?.rating, surface.store?.ratingCount) && (
                  <span class="surface__rating">
                    {fmtRating(surface.store?.rating, surface.store?.ratingCount)}
                  </span>
                )}
                {!surface.store && surface.downloads > 0 && (
                  <span class="surface__downloads">{fmtDownloads(surface.downloads)}</span>
                )}
              </div>
            )}
          </header>

          {surface?.store && (key === "ios" || key === "android") && (
            <div class="surface__store">
              <StoreBadge store={key} href={surface.store.url} />
            </div>
          )}

          {dockerImage && (
            <ExternalLink
              class="docker-link"
              href={`https://hub.docker.com/r/${dockerImage}`}
              aria-label={`Pull ${name} from Docker Hub`}
            >
              <svg
                class="docker-link__mark"
                viewBox="0 0 24 24"
                width="20"
                height="20"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  fill="currentColor"
                  d="M13.983 11.078h2.119a.186.186 0 0 0 .186-.185V9.006a.186.186 0 0 0-.186-.186h-2.119a.185.185 0 0 0-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 0 0 .186-.186V3.574a.186.186 0 0 0-.186-.185h-2.118a.185.185 0 0 0-.185.185v1.888c0 .102.082.185.185.185m0 2.716h2.118a.187.187 0 0 0 .186-.186V6.29a.186.186 0 0 0-.186-.185h-2.118a.185.185 0 0 0-.185.185v1.887c0 .102.082.186.185.186m-2.93 0h2.12a.186.186 0 0 0 .184-.186V6.29a.185.185 0 0 0-.185-.185H8.1a.185.185 0 0 0-.185.185v1.887c0 .102.083.186.185.186m-2.964 0h2.119a.186.186 0 0 0 .185-.186V6.29a.185.185 0 0 0-.185-.185H5.136a.186.186 0 0 0-.186.185v1.887c0 .102.084.186.186.186m5.893 2.715h2.118a.186.186 0 0 0 .186-.185V9.006a.186.186 0 0 0-.186-.186h-2.118a.185.185 0 0 0-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 0 0 .184-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.185.185 0 0 0-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 0 0 .185-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.186.186 0 0 0-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.185.185 0 0 0 .184-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.185.185 0 0 0-.184.185v1.888c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 0 0-.75.748 11.376 11.376 0 0 0 .692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137a16.09 16.09 0 0 0 2.928-.266 12.11 12.11 0 0 0 3.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288z"
                />
              </svg>
              Pull from Docker Hub
            </ExternalLink>
          )}

          {surface && surface.binaries.length > 0 ? (
            <>
              {surface.store && <p class="downloads__label">Direct download</p>}
              <ul class={surface.store ? "downloads downloads--secondary" : "downloads"}>
                {surface.binaries.map((b) => (
                  <li>
                    <a class="download" href={b.url} rel="noopener">
                      <span class="download__os">{b.os}</span>
                      {b.arch && <span class="download__arch">{b.arch}</span>}
                      <span class="download__size">{b.size}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            !surface?.store && (
              <p class="surface__fallback">
                No direct binaries listed for this release.{" "}
                <ExternalLink href={surface?.releaseUrl ?? `https://github.com/${repo}/releases`}>
                  Browse releases on GitHub →
                </ExternalLink>
              </p>
            )
          )}

          <a class="surface__history" href={withBase(base, `downloads/${key}`)}>
            View all releases →
          </a>
        </article>
      ))
    }
  </section>
</Base>

<style>
  /* ---------- Hero (shared visual language with the home page) ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(130% 100% at 80% -10%, #1d3a66 0%, var(--oc-brand) 55%, #03152f 100%);
    color: #fff;
    isolation: isolate;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 78%);
    z-index: -1;
  }
  .hero__glow {
    position: absolute;
    width: 620px;
    height: 620px;
    right: -160px;
    top: -260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(74, 118, 172, 0.55), transparent 65%);
    filter: blur(20px);
    z-index: -1;
  }
  .hero__inner {
    padding-block: 84px 72px;
    max-width: 860px;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    font-weight: 700;
    color: #8fb4e3;
    margin: 0 0 20px;
  }
  .hero__title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    margin: 0 0 22px;
  }
  .hero__accent {
    position: relative;
    white-space: nowrap;
  }
  .hero__accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.14em;
    background: linear-gradient(90deg, #4a76ac, #8fb4e3);
    border-radius: 2px;
  }
  .hero__lede {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 620px;
    margin: 0 0 18px;
  }
  .hero__note {
    font-size: 0.86rem;
    color: #8fb4e3;
    margin: 0;
  }

  /* ---------- Surfaces ---------- */
  .surfaces {
    padding-top: 64px;
    display: grid;
    gap: 26px;
  }
  .surface {
    padding: 28px;
    background: var(--oc-bg);
    border: 1px solid var(--oc-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .surface__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px 24px;
    margin-bottom: 22px;
  }
  .surface__name {
    font-size: 1.5rem;
    color: var(--oc-brand);
  }
  .surface__tagline {
    margin: 4px 0 0;
    color: var(--oc-text-muted);
    font-size: 0.96rem;
  }
  .surface__release {
    text-align: right;
    flex: none;
  }
  .surface__version {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--oc-bg-highlight);
    color: var(--oc-primary-hover);
  }
  .surface__version:hover {
    text-decoration: none;
    background: var(--oc-border-input);
  }
  .surface__date {
    display: block;
    margin-top: 6px;
    font-size: 0.82rem;
    color: var(--oc-text-muted);
  }
  .surface__downloads {
    display: block;
    margin-top: 4px;
    font-size: 0.82rem;
    color: var(--oc-text-muted);
  }
  .surface__rating {
    display: block;
    margin-top: 4px;
    font-size: 0.82rem;
    color: var(--oc-text-muted);
  }

  .downloads__label {
    margin: 22px 0 10px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--oc-text-muted);
  }
  .downloads--secondary .download {
    padding: 10px 14px;
    font-size: 0.92rem;
  }

  /* The store badge sits on its own line; without binaries below it there is
     no block element to separate it from the inline "View all releases" link,
     so wrap it in a block container (matching the .downloads list on the other
     surfaces) to keep that link on the next row. */
  .surface__store {
    margin-bottom: 4px;
  }

  /* ---------- Docker Hub link ---------- */
  .docker-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 14px;
    padding: 10px 16px;
    border-radius: var(--radius-sm);
    background: #1d63ed;
    color: #fff;
    font-weight: 600;
    font-size: 0.92rem;
    transition:
      background 0.16s ease,
      transform 0.16s ease;
  }
  .docker-link:hover {
    background: #1a56d0;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .docker-link:focus-visible {
    outline: 3px solid var(--oc-primary);
    outline-offset: 3px;
  }
  .docker-link__mark {
    flex: none;
  }

  .surface__history {
    display: inline-block;
    margin-top: 18px;
    font-weight: 600;
    font-size: 0.92rem;
  }

  /* ---------- Binary download buttons ---------- */
  .downloads {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 12px;
  }
  .download {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    border: 1px solid var(--oc-border-input);
    border-radius: var(--radius-sm);
    background: var(--oc-bg);
    color: var(--oc-text);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .download:hover {
    text-decoration: none;
    transform: translateY(-2px);
    border-color: var(--oc-primary);
    box-shadow: var(--shadow-md);
  }
  .download__os {
    font-weight: 700;
    color: var(--oc-brand);
    white-space: nowrap;
  }
  .download__arch {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--oc-text-muted);
    white-space: nowrap;
  }
  .download__size {
    margin-left: auto;
    padding-left: 8px;
    font-size: 0.82rem;
    color: var(--oc-text-muted);
    white-space: nowrap;
  }

  .surface__fallback {
    margin: 0;
    color: var(--oc-text-muted);
    font-size: 0.96rem;
  }
</style>
