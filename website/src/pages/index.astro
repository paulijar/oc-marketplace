---
import Base from "../layouts/Base.astro";
import { loadApps, loadCategories, withBase } from "../lib/catalog.ts";

const apps = await loadApps();
const categories = await loadCategories();
const base = import.meta.env.BASE_URL;

// Only surface categories that actually have apps, with their counts.
const counts = new Map<string, number>();
for (const app of apps) {
  for (const c of app.categories) counts.set(c, (counts.get(c) ?? 0) + 1);
}
const activeCategories = categories.filter((c) => counts.has(c.id));

const publisherCount = new Set(apps.map((a) => a.publisher.name)).size;
const releaseCount = apps.reduce((n, a) => n + a.releases.length, 0);

const categoryName = (id: string) =>
  categories.find((c) => c.id === id)?.name ?? id;

const initial = (name: string) => name.trim().charAt(0).toUpperCase() || "?";
---
<Base
  title="ownCloud Marketplace — apps for your ownCloud"
  description="Browse and publish apps for ownCloud. A backend-free, community-driven catalog where the Git repository is the source of truth."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="eyebrow">Open Source Program Office · Community Catalog</p>
      <h1 class="hero__title">
        Apps that extend <span class="hero__accent">ownCloud</span>.
      </h1>
      <p class="hero__lede">
        Discover community and partner extensions for your ownCloud server —
        validated in the open, versioned in Git, and served as static JSON.
      </p>
      <div class="hero__actions">
        <a class="btn btn--solid" href="#catalog">Browse {apps.length}
          {apps.length === 1 ? "app" : "apps"}</a>
        <a
          class="btn btn--ghost"
          href="https://github.com/owncloud/marketplace/blob/main/.github/pull_request_template.md"
          >Publish your app →</a
        >
      </div>
      <dl class="hero__stats">
        <div>
          <dt>Apps</dt>
          <dd>{apps.length}</dd>
        </div>
        <div>
          <dt>Releases</dt>
          <dd>{releaseCount}</dd>
        </div>
        <div>
          <dt>Publishers</dt>
          <dd>{publisherCount}</dd>
        </div>
        <div>
          <dt>Categories</dt>
          <dd>{activeCategories.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ===================== CATALOG ===================== -->
  <section id="catalog" class="catalog container">
    <div class="catalog__head">
      <h2>Explore the catalog</h2>
      <label class="search">
        <svg
          class="search__icon"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          aria-hidden="true"
          ><path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            d="m21 21-4.3-4.3M11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z"></path></svg
        >
        <input
          id="app-search"
          type="search"
          placeholder="Search apps…"
          autocomplete="off"
          aria-label="Search apps"
        />
      </label>
    </div>

    <div class="filters" role="group" aria-label="Filter by category">
      <button class="chip is-active" data-category="all" type="button"
        >All<span class="chip__count">{apps.length}</span></button
      >
      {
        activeCategories.map((c) => (
          <button class="chip" data-category={c.id} type="button">
            {c.name}
            <span class="chip__count">{counts.get(c.id)}</span>
          </button>
        ))
      }
    </div>

    <ul class="grid" id="app-grid">
      {
        apps.map((app) => (
          <li
            class="card-item"
            data-name={app.name.toLowerCase()}
            data-description={app.description.toLowerCase()}
            data-categories={app.categories.join(" ")}
          >
            <a class="card" href={withBase(base, `apps/${app.id}`)}>
              <div class="card__top">
                <span class="card__avatar" aria-hidden="true">
                  {initial(app.name)}
                </span>
                <div class="card__heading">
                  <h3 class="card__title">{app.name}</h3>
                  <span class="card__publisher">{app.publisher.name}</span>
                </div>
              </div>
              <p class="card__desc">{app.description}</p>
              <div class="card__meta">
                <div class="card__cats">
                  {app.categories.map((c) => (
                    <span class="tag">{categoryName(c)}</span>
                  ))}
                </div>
                {app.releases[0] && (
                  <span class="card__version">v{app.releases[0].version}</span>
                )}
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="empty" id="empty-state" hidden>
      No apps match your search. Try a different term or category.
    </p>
  </section>

  <!-- ===================== PUBLISH CTA ===================== -->
  <section class="publish">
    <div class="container publish__inner">
      <div class="publish__copy">
        <h2>Publish in three steps</h2>
        <p>
          There is no upload form and no account to create. Open a pull request
          adding a single tarball — CI validates it against the catalog rules,
          and once merged the API and this site regenerate automatically.
        </p>
        <a
          class="btn btn--solid"
          href="https://github.com/owncloud/marketplace/blob/main/.github/pull_request_template.md"
          >Read the publishing guide →</a
        >
      </div>
      <ol class="steps">
        <li>
          <span class="steps__num">1</span>
          <div>
            <h3>Add your package</h3>
            <p>
              Commit <code>apps/&lt;id&gt;/releases/&lt;version&gt;/package.tar.gz</code
              > — all metadata is read from the <code>info.xml</code> inside it.
            </p>
          </div>
        </li>
        <li>
          <span class="steps__num">2</span>
          <div>
            <h3>Open a pull request</h3>
            <p>
              Automated validation checks your manifest, versions and platform
              constraints, then reports back on the PR.
            </p>
          </div>
        </li>
        <li>
          <span class="steps__num">3</span>
          <div>
            <h3>Ship on merge</h3>
            <p>
              Merge to <code>main</code> and the catalog, JSON API and this page
              rebuild and deploy to GitHub Pages.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</Base>

<script is:inline>
  (() => {
    const search = document.getElementById("app-search");
    const grid = document.getElementById("app-grid");
    const empty = document.getElementById("empty-state");
    const chips = Array.from(document.querySelectorAll(".chip"));
    const cards = Array.from(grid.querySelectorAll(".card-item"));
    let activeCategory = "all";

    function apply() {
      const q = (search.value || "").trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const matchesCat =
          activeCategory === "all" ||
          card.dataset.categories.split(" ").includes(activeCategory);
        const matchesText =
          !q ||
          card.dataset.name.includes(q) ||
          card.dataset.description.includes(q);
        const show = matchesCat && matchesText;
        card.hidden = !show;
        if (show) visible++;
      }
      empty.hidden = visible !== 0;
    }

    search.addEventListener("input", apply);
    for (const chip of chips) {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active"));
        chip.classList.add("is-active");
        activeCategory = chip.dataset.category;
        apply();
      });
    }
  })();
</script>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        130% 100% at 80% -10%,
        #1d3a66 0%,
        var(--oc-brand) 55%,
        #03152f 100%
      );
    color: #fff;
    isolation: isolate;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 78%);
    z-index: -1;
  }
  .hero__glow {
    position: absolute;
    width: 620px;
    height: 620px;
    right: -160px;
    top: -260px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(74, 118, 172, 0.55),
      transparent 65%
    );
    filter: blur(20px);
    z-index: -1;
  }
  .hero__inner {
    padding-block: 96px 84px;
    max-width: 860px;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    font-weight: 700;
    color: #8fb4e3;
    margin: 0 0 20px;
  }
  .hero__title {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    font-weight: 700;
    margin: 0 0 22px;
  }
  .hero__accent {
    position: relative;
    white-space: nowrap;
  }
  .hero__accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.14em;
    background: linear-gradient(90deg, #4a76ac, #8fb4e3);
    border-radius: 2px;
  }
  .hero__lede {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 620px;
    margin: 0 0 34px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 56px;
  }
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: 560px;
  }
  .hero__stats > div {
    background: rgba(4, 30, 66, 0.35);
    padding: 18px 20px;
    backdrop-filter: blur(4px);
  }
  .hero__stats dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8fb4e3;
  }
  .hero__stats dd {
    margin: 4px 0 0;
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1;
  }
  @media (max-width: 560px) {
    .hero__stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ---------- Buttons ---------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 1rem;
    padding: 13px 24px;
    border-radius: 999px;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }
  .btn--solid {
    background: #fff;
    color: var(--oc-brand);
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.5);
  }
  .btn--solid:hover {
    box-shadow: 0 16px 40px -14px rgba(0, 0, 0, 0.6);
  }
  .btn--ghost {
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  .btn--ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  /* ---------- Catalog ---------- */
  .catalog {
    padding-top: 72px;
    scroll-margin-top: 84px;
  }
  .catalog__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 22px;
  }
  .catalog__head h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
  }
  .search {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-width: 280px;
  }
  .search__icon {
    position: absolute;
    left: 14px;
    color: var(--oc-text-muted);
    pointer-events: none;
  }
  .search input {
    width: 100%;
    font: inherit;
    padding: 11px 16px 11px 42px;
    border: 1px solid var(--oc-border-input);
    border-radius: 999px;
    background: var(--oc-bg);
    color: var(--oc-text);
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .search input:focus {
    outline: none;
    border-color: var(--oc-primary);
    box-shadow: 0 0 0 4px rgba(74, 118, 172, 0.15);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 34px;
  }
  .chip {
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: 999px;
    border: 1px solid var(--oc-border);
    background: var(--oc-bg);
    color: var(--oc-text-muted);
    transition:
      background 0.16s ease,
      color 0.16s ease,
      border-color 0.16s ease;
  }
  .chip:hover {
    border-color: var(--oc-primary);
    color: var(--oc-brand);
  }
  .chip.is-active {
    background: var(--oc-brand);
    border-color: var(--oc-brand);
    color: #fff;
  }
  .chip__count {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 1px 8px;
    border-radius: 999px;
    background: var(--oc-bg-highlight);
    color: var(--oc-primary-hover);
  }
  .chip.is-active .chip__count {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* ---------- Card grid ---------- */
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 22px;
  }
  .card-item[hidden] {
    display: none;
  }
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px;
    background: var(--oc-bg);
    border: 1px solid var(--oc-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    color: inherit;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--oc-border-input);
  }
  .card__top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .card__avatar {
    flex: none;
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 11px;
    font-weight: 700;
    font-size: 1.25rem;
    color: #fff;
    background: linear-gradient(135deg, var(--oc-primary), var(--oc-brand));
  }
  .card__heading {
    min-width: 0;
  }
  .card__title {
    font-size: 1.16rem;
    font-weight: 700;
    color: var(--oc-brand);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card__publisher {
    font-size: 0.85rem;
    color: var(--oc-text-muted);
  }
  .card__desc {
    margin: 0 0 20px;
    color: var(--oc-text-muted);
    font-size: 0.96rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__meta {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .card__cats {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--oc-bg-highlight);
    color: var(--oc-primary-hover);
  }
  .card__version {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--oc-text-muted);
  }
  .empty {
    text-align: center;
    color: var(--oc-text-muted);
    padding: 48px 0;
    font-size: 1.05rem;
  }

  /* ---------- Publish ---------- */
  .publish {
    margin-top: 88px;
    background: var(--oc-bg-highlight);
    border-block: 1px solid var(--oc-border);
  }
  .publish__inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    padding-block: 72px;
    align-items: start;
  }
  .publish__copy h2 {
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    margin-bottom: 16px;
  }
  .publish__copy p {
    color: var(--oc-text-muted);
    font-size: 1.05rem;
    margin: 0 0 26px;
  }
  .publish__copy .btn--solid {
    background: var(--oc-brand);
    color: #fff;
    box-shadow: var(--shadow-md);
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
  .steps li {
    display: flex;
    gap: 18px;
    padding: 22px 24px;
    background: var(--oc-bg);
    border: 1px solid var(--oc-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .steps__num {
    flex: none;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--oc-brand);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .steps h3 {
    font-size: 1.1rem;
    margin: 3px 0 6px;
    color: var(--oc-brand);
  }
  .steps p {
    margin: 0;
    color: var(--oc-text-muted);
    font-size: 0.95rem;
  }
  .steps code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--oc-bg-highlight);
    padding: 1px 6px;
    border-radius: 5px;
    color: var(--oc-primary-hover);
    word-break: break-word;
  }
  @media (max-width: 820px) {
    .publish__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
