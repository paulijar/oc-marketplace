---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/catalog.ts";
import { loadExtensions } from "../../lib/extensions.ts";

const extensions = await loadExtensions();
const base = import.meta.env.BASE_URL;

// Absolute URL of the oCIS repository feed an admin adds to their app-store
// config. Built from the configured site + base so it is correct per deployment.
const feedUrl = new URL(withBase(base, "api/ocis/v1/apps.json"), Astro.site).href;

// Surface every tag that appears, with its extension count, for the filter chips.
const counts = new Map<string, number>();
for (const ext of extensions) {
  for (const t of ext.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
}
const tags = [...counts.keys()].sort();

const authorCount = new Set(extensions.flatMap((e) => e.authors.map((a) => a.name))).size;
const versionCount = extensions.reduce((n, e) => n + e.versions.length, 0);

const initial = (name: string) => name.trim().charAt(0).toUpperCase() || "?";
---
<Base
  title="oCIS Web Extensions — ownCloud Marketplace"
  description="Discover web extensions for ownCloud Infinite Scale (oCIS). Add the repository to your oCIS app store and install extensions at runtime."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="eyebrow">ownCloud Infinite Scale · Web Extensions</p>
      <h1 class="hero__title">
        Extend <span class="hero__accent">Infinite Scale</span> at runtime.
      </h1>
      <p class="hero__lede">
        Web extensions add features to the ownCloud Web frontend — validated in
        the open, versioned in Git, and served as a drop-in oCIS app-store
        repository feed.
      </p>
      <div class="hero__actions">
        <a class="btn btn--solid" href="#catalog">Browse {extensions.length}
          {extensions.length === 1 ? "extension" : "extensions"}</a>
        <a class="btn btn--ghost" href="#use-in-ocis">Use in oCIS →</a>
      </div>
      <dl class="hero__stats">
        <div>
          <dt>Extensions</dt>
          <dd>{extensions.length}</dd>
        </div>
        <div>
          <dt>Versions</dt>
          <dd>{versionCount}</dd>
        </div>
        <div>
          <dt>Authors</dt>
          <dd>{authorCount}</dd>
        </div>
        <div>
          <dt>Tags</dt>
          <dd>{tags.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ===================== CATALOG ===================== -->
  <section id="catalog" class="catalog container">
    <div class="catalog__head">
      <h2>Explore extensions</h2>
      <label class="search">
        <svg
          class="search__icon"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          aria-hidden="true"
          ><path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            d="m21 21-4.3-4.3M11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z"></path></svg
        >
        <input
          id="ext-search"
          type="search"
          placeholder="Search extensions…"
          autocomplete="off"
          aria-label="Search extensions"
        />
      </label>
    </div>

    {
      tags.length > 0 && (
        <div class="filters" role="group" aria-label="Filter by tag">
          <button class="chip is-active" data-tag="all" type="button">
            All<span class="chip__count">{extensions.length}</span>
          </button>
          {tags.map((t) => (
            <button class="chip" data-tag={t} type="button">
              {t}
              <span class="chip__count">{counts.get(t)}</span>
            </button>
          ))}
        </div>
      )
    }

    {
      extensions.length === 0 ? (
        <p class="empty">
          No web extensions published yet. Check back soon, or open a pull
          request to publish the first one.
        </p>
      ) : (
        <ul class="grid" id="ext-grid">
          {extensions.map((ext) => (
            <li
              class="card-item"
              data-name={ext.name.toLowerCase()}
              data-subtitle={ext.subtitle.toLowerCase()}
              data-tags={ext.tags.join(" ")}
            >
              <a class="card" href={withBase(base, `extensions/${ext.id}`)}>
                <div class="card__top">
                  <span class="card__avatar" aria-hidden="true">
                    {initial(ext.name)}
                  </span>
                  <div class="card__heading">
                    <h3 class="card__title">{ext.name}</h3>
                    <span class="card__publisher">{ext.authors[0]?.name}</span>
                  </div>
                </div>
                <p class="card__desc">{ext.subtitle}</p>
                <div class="card__meta">
                  <div class="card__cats">
                    {ext.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  {ext.versions[0] && (
                    <span class="card__version">v{ext.versions[0].version}</span>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <p class="empty" id="empty-state" hidden>
      No extensions match your search. Try a different term or tag.
    </p>
  </section>

  <!-- ===================== USE IN oCIS ===================== -->
  <section id="use-in-ocis" class="use">
    <div class="container use__inner">
      <div class="use__copy">
        <h2>Use in ownCloud Infinite Scale</h2>
        <p>
          This catalog is a drop-in oCIS app-store repository. Add the feed URL
          to your oCIS Web app-store configuration and the extensions below
          appear in the in-product App Store, ready to download and install.
        </p>
        <p class="use__hint">Repository feed URL</p>
        <code class="use__url">{feedUrl}</code>
      </div>
      <ol class="steps">
        <li>
          <span class="steps__num">1</span>
          <div>
            <h3>Add the repository</h3>
            <p>
              Add the feed URL above to the <code>web</code> app's app-store
              <code>repositories</code> configuration in oCIS.
            </p>
          </div>
        </li>
        <li>
          <span class="steps__num">2</span>
          <div>
            <h3>Pick an extension</h3>
            <p>
              Open the App Store in ownCloud Web, browse this catalog, and
              choose a version compatible with your oCIS release.
            </p>
          </div>
        </li>
        <li>
          <span class="steps__num">3</span>
          <div>
            <h3>Install &amp; restart</h3>
            <p>
              Deploy the downloaded bundle into the oCIS web assets apps
              directory and restart the web service to load it.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</Base>

<script is:inline>
  (() => {
    const search = document.getElementById("ext-search");
    const grid = document.getElementById("ext-grid");
    const empty = document.getElementById("empty-state");
    if (!grid) return;
    const chips = Array.from(document.querySelectorAll(".chip"));
    const cards = Array.from(grid.querySelectorAll(".card-item"));
    let activeTag = "all";

    function apply() {
      const q = (search.value || "").trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const matchesTag =
          activeTag === "all" ||
          card.dataset.tags.split(" ").includes(activeTag);
        const matchesText =
          !q ||
          card.dataset.name.includes(q) ||
          card.dataset.subtitle.includes(q);
        const show = matchesTag && matchesText;
        card.hidden = !show;
        if (show) visible++;
      }
      empty.hidden = visible !== 0;
    }

    search.addEventListener("input", apply);
    for (const chip of chips) {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active"));
        chip.classList.add("is-active");
        activeTag = chip.dataset.tag;
        apply();
      });
    }
  })();
</script>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        130% 100% at 80% -10%,
        #1d3a66 0%,
        var(--oc-brand) 55%,
        #03152f 100%
      );
    color: #fff;
    isolation: isolate;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 78%);
    z-index: -1;
  }
  .hero__glow {
    position: absolute;
    width: 620px;
    height: 620px;
    right: -160px;
    top: -260px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(74, 118, 172, 0.55),
      transparent 65%
    );
    filter: blur(20px);
    z-index: -1;
  }
  .hero__inner {
    padding-block: 96px 84px;
    max-width: 860px;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    font-weight: 700;
    color: #8fb4e3;
    margin: 0 0 20px;
  }
  .hero__title {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    font-weight: 700;
    margin: 0 0 22px;
  }
  .hero__accent {
    position: relative;
    white-space: nowrap;
  }
  .hero__accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.14em;
    background: linear-gradient(90deg, #4a76ac, #8fb4e3);
    border-radius: 2px;
  }
  .hero__lede {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 620px;
    margin: 0 0 34px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 56px;
  }
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: 560px;
  }
  .hero__stats > div {
    background: rgba(4, 30, 66, 0.35);
    padding: 18px 20px;
    backdrop-filter: blur(4px);
  }
  .hero__stats dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8fb4e3;
  }
  .hero__stats dd {
    margin: 4px 0 0;
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1;
  }
  @media (max-width: 560px) {
    .hero__stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ---------- Buttons ---------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 1rem;
    padding: 13px 24px;
    border-radius: 999px;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }
  .btn--solid {
    background: #fff;
    color: var(--oc-brand);
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.5);
  }
  .btn--solid:hover {
    box-shadow: 0 16px 40px -14px rgba(0, 0, 0, 0.6);
  }
  .btn--ghost {
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  .btn--ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  /* ---------- Catalog ---------- */
  .catalog {
    padding-top: 72px;
    scroll-margin-top: 84px;
  }
  .catalog__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 22px;
  }
  .catalog__head h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
  }
  .search {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-width: 280px;
  }
  .search__icon {
    position: absolute;
    left: 14px;
    color: var(--oc-text-muted);
    pointer-events: none;
  }
  .search input {
    width: 100%;
    font: inherit;
    padding: 11px 16px 11px 42px;
    border: 1px solid var(--oc-border-input);
    border-radius: 999px;
    background: var(--oc-bg);
    color: var(--oc-text);
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .search input:focus {
    outline: none;
    border-color: var(--oc-primary);
    box-shadow: 0 0 0 4px rgba(74, 118, 172, 0.15);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 34px;
  }
  .chip {
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: 999px;
    border: 1px solid var(--oc-border);
    background: var(--oc-bg);
    color: var(--oc-text-muted);
    transition:
      background 0.16s ease,
      color 0.16s ease,
      border-color 0.16s ease;
  }
  .chip:hover {
    border-color: var(--oc-primary);
    color: var(--oc-brand);
  }
  .chip.is-active {
    background: var(--oc-brand);
    border-color: var(--oc-brand);
    color: #fff;
  }
  .chip__count {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 1px 8px;
    border-radius: 999px;
    background: var(--oc-bg-highlight);
    color: var(--oc-primary-hover);
  }
  .chip.is-active .chip__count {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* ---------- Card grid ---------- */
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 22px;
  }
  .card-item[hidden] {
    display: none;
  }
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px;
    background: var(--oc-bg);
    border: 1px solid var(--oc-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    color: inherit;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--oc-border-input);
  }
  .card__top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .card__avatar {
    flex: none;
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 11px;
    font-weight: 700;
    font-size: 1.25rem;
    color: #fff;
    background: linear-gradient(135deg, var(--oc-primary), var(--oc-brand));
  }
  .card__heading {
    min-width: 0;
  }
  .card__title {
    font-size: 1.16rem;
    font-weight: 700;
    color: var(--oc-brand);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card__publisher {
    font-size: 0.85rem;
    color: var(--oc-text-muted);
  }
  .card__desc {
    margin: 0 0 20px;
    color: var(--oc-text-muted);
    font-size: 0.96rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__meta {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .card__cats {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--oc-bg-highlight);
    color: var(--oc-primary-hover);
  }
  .card__version {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--oc-text-muted);
  }
  .empty {
    text-align: center;
    color: var(--oc-text-muted);
    padding: 48px 0;
    font-size: 1.05rem;
  }

  /* ---------- Use in oCIS ---------- */
  .use {
    margin-top: 88px;
    background: var(--oc-bg-highlight);
    border-block: 1px solid var(--oc-border);
  }
  .use__inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    padding-block: 72px;
    align-items: start;
  }
  .use__copy h2 {
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    margin-bottom: 16px;
  }
  .use__copy p {
    color: var(--oc-text-muted);
    font-size: 1.05rem;
    margin: 0 0 18px;
  }
  .use__hint {
    font-size: 0.72rem !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 8px !important;
    font-weight: 700;
  }
  .use__url {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--oc-bg);
    border: 1px solid var(--oc-border-input);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    color: var(--oc-primary-hover);
    word-break: break-all;
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
  .steps li {
    display: flex;
    gap: 18px;
    padding: 22px 24px;
    background: var(--oc-bg);
    border: 1px solid var(--oc-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .steps__num {
    flex: none;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--oc-brand);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .steps h3 {
    font-size: 1.1rem;
    margin: 3px 0 6px;
    color: var(--oc-brand);
  }
  .steps p {
    margin: 0;
    color: var(--oc-text-muted);
    font-size: 0.95rem;
  }
  .steps code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--oc-bg-highlight);
    padding: 1px 6px;
    border-radius: 5px;
    color: var(--oc-primary-hover);
    word-break: break-word;
  }
  @media (max-width: 820px) {
    .use__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
